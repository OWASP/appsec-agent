{
  "name": "appsec-agent",
  "version": "0.3.7",
  "description": "TypeScript package for AppSec AI Agent management",
  "author": "Sam Li",
  "date": "Jan 21 2026",
  "license": "MIT",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist",
    "conf"
  ],
  "bin": {
    "agent-run": "./dist/bin/agent-run.js"
  },
  "scripts": {
    "build": "tsc && cp -r conf dist/ && chmod +x dist/bin/agent-run.js",
    "start": "node dist/src/main.js",
    "dev": "ts-node src/main.ts",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "keywords": [
    "appsec",
    "ai-agent",
    "claude",
    "security",
    "typescript"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.76",
    "yaml": "^2.4.0",
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.10.0",
    "@types/fs-extra": "^11.0.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-code": "2.0.65"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
